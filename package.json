{
  "name": "oc-durable-sessions-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A code-first presentation prototype for OpenComputer Durable Agent Sessions",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"tsx watch server/index.ts\" \"vite\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "concurrently -k -n api,web -c yellow,cyan \"tsx server/index.ts\" \"vite preview\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@opencomputer/sdk": "^0.12.4",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.10"
  }
}
