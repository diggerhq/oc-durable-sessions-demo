# Required. These values stay in the local Node process; the browser never receives them.
OPENCOMPUTER_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Required by the Durable session screen. This is an id, not a credential.
DEMO_SESSION_AGENT_ID=agt_...

# Optional overrides. The first two screens write only to this disposable repo.
DEMO_TARGET_REPO=diggerhq/oc-agent-demo-target
DEMO_TARGET_BRANCH=main
DEMO_SECURITY_MODEL=claude-haiku-4-5

# Optional service/port overrides; these defaults work against production.
OPENCOMPUTER_SANDBOX_API_URL=https://app.opencomputer.dev
OPENCOMPUTER_SESSIONS_API_URL=https://api.opencomputer.dev/v3
OPENCOMPUTER_DASHBOARD_URL=https://app.opencomputer.dev
DEMO_API_PORT=8789
