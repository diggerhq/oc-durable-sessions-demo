# The org key stays in the local Node process. It is never sent to the browser.
OPENCOMPUTER_API_KEY=
OPENCOMPUTER_API_URL=https://api.opencomputer.dev/v3
OPENCOMPUTER_DASHBOARD_URL=https://app.opencomputer.dev

# auto: use a live agent when its id and the org key are present, mock otherwise.
# mock: never call OpenComputer. live: fail instead of silently falling back.
DEMO_MODE=auto

# A live stand-in can back each proposed inline-agent example until that API exists.
OC_DEMO_CLAUDE_AGENT_ID=
OC_DEMO_CODEX_AGENT_ID=
OC_DEMO_INLINE_AGENT_ID=

# These three examples use the public sessions.create({ agent, input }) contract directly.
OC_DEMO_SAVED_AGENT_ID=
OC_DEMO_REPO_AGENT_ID=
OC_DEMO_FLUE_AGENT_ID=

# Local API server used by the Vite proxy.
DEMO_API_PORT=8789

