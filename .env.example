# These values stay in the local Node process. The browser never receives them.
OPENCOMPUTER_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# The first demo writes only to this disposable GitHub repository.
DEMO_TARGET_REPO=diggerhq/oc-agent-demo-target
DEMO_TARGET_BRANCH=main

OPENCOMPUTER_SANDBOX_API_URL=https://app.opencomputer.dev
OPENCOMPUTER_DASHBOARD_URL=https://app.opencomputer.dev
DEMO_API_PORT=8789
